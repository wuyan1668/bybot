# ============================================================
#  组合策略 v2.0 - 环境配置文件
#  复制此文件为 .env 并填入你的真实密钥
# ============================================================

# -------------------- 交易所配置 --------------------
# 交易所选择: binance / bybit
EXCHANGE_NAME=bybit

# API Key (Bybit Demo 用真实API Key, Binance Demo 也用真实API Key)
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# 模式: demo=模拟盘, live=实盘
# Bybit Demo: ccxt 原生 enable_demo_trading, 使用真实API Key
# Binance Demo: 手动覆盖URL到 demo-fapi.binance.com, 使用真实API Key
TRADING_MODE=demo
# DRY_RUN=true 时只记录和模拟下单/撤单，不会发送任何交易所写操作
DRY_RUN=true
# 实盘保护: 当 TRADING_MODE=live 且 DRY_RUN=false 时，必须显式设置为 I_UNDERSTAND_LIVE_TRADING
LIVE_TRADING_CONFIRM=

# -------------------- Telegram 通知 --------------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# 通知级别: all=所有事件, trade=仅交易, critical=仅紧急
NOTIFY_LEVEL=all
# 机器人默认每 30 分钟推送一次中文状态报告（代码内固定 1800 秒）

# -------------------- 资金配置 --------------------
TOTAL_CAPITAL=10000
ORDER_GUARD_ENABLED=true
MIN_FREE_BALANCE_PCT=0.05
MAX_SYMBOL_NOTIONAL_PCT=0.60
MAX_TOTAL_NOTIONAL_PCT=1.50
# 资金分配比例 (总和=1.0)
ALLOC_FUNDING_ARB=0.50
ALLOC_DYNAMIC_GRID=0.30
ALLOC_TREND_DCA=0.20
ALLOW_SHARED_SYMBOLS=false

# -------------------- 全局风控 --------------------
MAX_TOTAL_DRAWDOWN=0.15
MAX_STRATEGY_DRAWDOWN=0.10
MAX_DAILY_LOSS=0.05
EMERGENCY_STOP_LOSS=0.20
# 当账户空仓且无挂单时，允许在启动阶段把风控资金基准重置为当前权益，避免旧 TOTAL_CAPITAL/历史快照导致立即 STOP_ALL
AUTO_RESET_RISK_BASELINE=false
# live 模式下如需自动重置基准，必须显式确认
RISK_BASELINE_RESET_CONFIRM=
# 重启/异常演练: >0 时在对应主循环周期故意抛出异常, 用于验证快照恢复流程
REHEARSAL_EXCEPTION_CYCLE=0
CHECK_INTERVAL=60

# -------------------- 市场状态检测 --------------------
ADX_PERIOD=14
ADX_TREND_THRESHOLD=25
ADX_RANGE_THRESHOLD=20

# -------------------- 策略一: 资金费率套利 --------------------
FUNDING_SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT
FUNDING_MIN_RATE=0.0005
FUNDING_LEVERAGE=1
FUNDING_POSITION_RATIO=0.45
FUNDING_CHECK_INTERVAL=300
FUNDING_CLOSE_THRESHOLD=0.0001
FUNDING_MAX_POSITIONS=2
# 实盘保护: funding_arb 默认不允许参与 live；如确需开启，显式设置为 ENABLE_FUNDING_ARB_LIVE
FUNDING_LIVE_CONFIRM=

# -------------------- 策略二: 动态网格 --------------------
GRID_SYMBOL=BTC/USDT:USDT
GRID_COUNT=10
GRID_SPACING_PCT=0.005
GRID_ATR_PERIOD=14
GRID_ATR_MULTIPLIER=1.5
GRID_ORDER_AMOUNT_PCT=0.08
GRID_LEVERAGE=3
GRID_MAX_OPEN_ORDERS=10
GRID_RECENTER_THRESHOLD=0.03
GRID_UPDATE_INTERVAL=120
# 人工恢复入口: 当 dynamic_grid 因挂单/状态不一致被暂停后，确认当前无残余仓位且允许清空本地旧网格并重建时设置为 REBUILD_DYNAMIC_GRID
GRID_REBUILD_CONFIRM=

# -------------------- 策略三: 趋势DCA --------------------
DCA_SYMBOL=BTC/USDT:USDT
DCA_FAST_MA=7
DCA_SLOW_MA=25
DCA_TIMEFRAME=4h
DCA_LAYERS=5
DCA_LAYER_SPACING_PCT=0.02
DCA_LAYER_MULTIPLIER=1.5
DCA_BASE_AMOUNT_PCT=0.10
DCA_LEVERAGE=2
DCA_TAKE_PROFIT_PCT=0.03
DCA_STOP_LOSS_PCT=0.08
DCA_CHECK_INTERVAL=300

# -------------------- 运行控制 --------------------
# 人工操作入口；留空表示不执行。示例：REPORT_RECONCILIATION / PAUSE_STRATEGY:trend_dca / RESUME_STRATEGY:dynamic_grid
OPERATOR_ACTION=
# 高风险动作二次确认；执行撤单/平仓/重建前需设置为 I_CONFIRM_OPERATOR_ACTION
OPERATOR_CONFIRM=

# -------------------- 熔断与 WebSocket --------------------
MAX_CONSECUTIVE_ORDER_FAILURES=3
MAX_CONSECUTIVE_DATA_FAILURES=3
MAX_CONSECUTIVE_STRATEGY_FAILURES=3
CIRCUIT_BREAKER_COOLDOWN_SEC=900
WEBSOCKET_ENABLED=false
WEBSOCKET_STALE_AFTER_SEC=180

# -------------------- 日志 --------------------
LOG_LEVEL=INFO
LOG_FILE=combo_strategy.log
